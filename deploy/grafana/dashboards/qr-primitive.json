{
  "annotations": { "list": [] },
  "description": "Lurus Platform — v2 QR primitive (/api/v2/qr/*). Session lifecycle, confirm latency, signature rejection, and per-action breakdown.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Session Lifecycle Rate",
      "type": "timeseries",
      "description": "Per-second rate of session creations, confirmations, and expiry/not-found lookups. A healthy system has created ≈ confirmed; a growing gap points to user drop-off.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(lurus_platform_qr_sessions_created_total[5m]))",
          "legendFormat": "created",
          "refId": "A"
        },
        {
          "expr": "sum(rate(lurus_platform_qr_confirmed_total[5m]))",
          "legendFormat": "confirmed",
          "refId": "B"
        },
        {
          "expr": "rate(lurus_platform_qr_expired_total[5m])",
          "legendFormat": "expired/404",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true },
          "unit": "ops"
        }
      }
    },
    {
      "title": "Confirm Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "description": "End-to-end latency of /api/v2/qr/:id/confirm. Dominated by Redis round-trips; p99 > 250 ms suggests Redis latency or a stuck Lua script.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(lurus_platform_qr_confirm_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(lurus_platform_qr_confirm_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(lurus_platform_qr_confirm_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "s"
        }
      }
    },
    {
      "title": "Signature Rejection Rate",
      "type": "timeseries",
      "description": "Confirm calls rejected for HMAC mismatch or stale timestamp. Sustained rate > 0.1/s may indicate tampering, a rogue client, or an APP/backend SESSION_SECRET mismatch after deploy.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "rate(lurus_platform_qr_signature_rejected_total[5m])",
          "legendFormat": "rejected/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          },
          "custom.thresholdsStyle": { "mode": "line" }
        }
      }
    },
    {
      "title": "Confirmed by Action (last 1h)",
      "type": "piechart",
      "description": "Relative mix of confirmed QR actions over the last hour. Today only `login` is wired; join_org / delegate will appear once their endpoints ship.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "expr": "sum by(action) (increase(lurus_platform_qr_confirmed_total[1h]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "title": "Delegate Confirms by Op",
      "type": "timeseries",
      "description": "Per-second rate of QR-delegate confirms broken down by op. Today's ops: delete_oidc_app (Phase 3), delete_account (Sprint 1A), approve_refund (Sprint 3A). Adding a new op produces a new line automatically — no dashboard change needed.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "sum by(op) (rate(lurus_platform_qr_delegate_confirms_total{result=\"success\"}[5m]))",
          "legendFormat": "{{op}} (ok)",
          "refId": "A"
        },
        {
          "expr": "sum by(op) (rate(lurus_platform_qr_delegate_confirms_total{result=\"failed\"}[5m]))",
          "legendFormat": "{{op}} (fail)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true },
          "unit": "ops"
        }
      }
    },
    {
      "title": "Delegate Failure Ratio (per op, last 1h)",
      "type": "stat",
      "description": "Failed / (success + failed) per op over the last hour. Sustained > 5% on any op means an executor cascade is misbehaving (e.g. Zitadel down for delete_oidc_app, refund service down for approve_refund). Empty cells = op not invoked in the window.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 18 },
      "targets": [
        {
          "expr": "sum by(op) (increase(lurus_platform_qr_delegate_confirms_total{result=\"failed\"}[1h])) / clamp_min(sum by(op) (increase(lurus_platform_qr_delegate_confirms_total[1h])), 1)",
          "legendFormat": "{{op}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Legacy Signature Share",
      "type": "timeseries",
      "description": "Fraction of confirm requests still using the pre-B5 (timestamp-less) HMAC payload, measured as legacy / (legacy + new). Deprecation target 2026-06-01 — if this stays above ~1% near the cutover, delay removal and re-check APP version rollout.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 27 },
      "targets": [
        {
          "expr": "sum(rate(lurus_platform_qr_legacy_signatures_total[15m])) / clamp_min(sum(rate(lurus_platform_qr_confirmed_total[15m])) + sum(rate(lurus_platform_qr_signature_rejected_total[15m])), 0.0001)",
          "legendFormat": "legacy share",
          "refId": "A"
        },
        {
          "expr": "rate(lurus_platform_qr_legacy_signatures_total[5m])",
          "legendFormat": "legacy/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "custom.thresholdsStyle": { "mode": "line" }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["lurus", "platform-core", "qr"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Shanghai",
  "title": "Lurus Platform — QR Primitive",
  "uid": "lurus-platform-qr",
  "version": 1
}
