{
  "name": "lurus-webmail",
  "private": true,
  "version": "0.0.3",
  "scripts": {
    "dev:web": "dotenvx run -f db/.env.develop -- bun run --cwd apps/web dev",
    "dev:docs": "dotenvx run -f db/.env.develop -- bun run --cwd apps/docs dev",
    "dev:worker": "dotenvx run -f db/.env.develop -- bun run --cwd apps/worker dev",
    "dev": "concurrently \"bun run dev:web\" \"bun run dev:worker\" \"bun run dev:docs\"",
    "build": "dotenvx run -f db/.env.develop -- bun run --cwd apps/web build",
    "build:worker": "dotenvx run -f db/.env.develop -- bun run --cwd apps/worker build",
    "deploy:docs": "git subtree push --prefix apps/docs dokku-docs main",
    "build:develop": "dotenvx run -f db/.env.develop -- bun run --cwd apps/web build",
    "deploy:db": "git subtree split --prefix=db -b deploy && git push origin deploy",
    "lint": "biome check",
    "format": "biome format --write",
    "changeset": "changeset",
    "publish-packages": "changeset publish",
    "version-packages": "changeset version && bun install && git add -A",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch"
  },
  "devDependencies": {
    "@aws-sdk/types": "3.910.0",
    "@biomejs/biome": "2.2.4",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@dotenvx/dotenvx": "^1.51.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.7.2",
    "@types/pg": "^8.15.5",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.5",
    "happy-dom": "^20.3.4",
    "jsdom": "^27.4.0",
    "tsx": "^4.20.6",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.910.0",
    "@aws-sdk/client-ses": "^3.910.0",
    "@aws-sdk/client-sesv2": "^3.910.0",
    "@aws-sdk/client-sns": "^3.910.0",
    "@aws-sdk/client-sts": "^3.910.0",
    "@aws-sdk/s3-request-presigner": "3.910.0",
    "@sindresorhus/slugify": "^3.0.0",
    "@supabase/supabase-js": "^2.75.0",
    "@vvo/tzdb": "^6.197.0",
    "bullmq": "^5.61.0",
    "crypto": "^1.0.1",
    "dayjs": "^1.11.19",
    "drizzle-orm": "^0.44.6",
    "drizzle-zod": "^0.8.3",
    "ioredis": "^5.8.1",
    "nanoid": "^5.1.6",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "typesense": "^2.1.0",
    "ulid": "^3.0.1",
    "uuid": "^13.0.0",
    "validator": "^13.15.15",
    "zod": "^4.1.12"
  },
  "overrides": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
