{
  "name": "@lurus/webmail-api-client",
  "private": true,
  "version": "1.0.0",
  "description": "Unified API client with tRPC for Lurus Webmail",
  "types": "src/index.ts",
  "main": "src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "import": "./src/hooks/index.ts"
    },
    "./react": {
      "types": "./src/react.tsx",
      "import": "./src/react.tsx"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": ["trpc", "api", "client", "react-query"],
  "author": "Lurus Team",
  "license": "AGPL-3.0",
  "dependencies": {
    "@tanstack/react-query": "^5.80.7",
    "@trpc/client": "^11.5.0",
    "@trpc/react-query": "^11.5.0",
    "@trpc/server": "^11.5.0",
    "superjson": "^2.2.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "react": "19.2.3",
    "vitest": "^3.2.3"
  }
}
