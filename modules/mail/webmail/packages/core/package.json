{
  "name": "@lurus/webmail-core",
  "private": true,
  "version": "1.0.0",
  "description": "Core business logic for Lurus Webmail",
  "types": "src/index.ts",
  "main": "src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./mail": {
      "types": "./src/mail/index.ts",
      "import": "./src/mail/index.ts"
    },
    "./calendar": {
      "types": "./src/calendar/index.ts",
      "import": "./src/calendar/index.ts"
    },
    "./contacts": {
      "types": "./src/contacts/index.ts",
      "import": "./src/contacts/index.ts"
    },
    "./rules": {
      "types": "./src/rules/index.ts",
      "import": "./src/rules/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": ["mail", "calendar", "contacts", "webmail"],
  "author": "Lurus Team",
  "license": "AGPL-3.0",
  "dependencies": {
    "dayjs": "^1.11.19",
    "zod": "^3.25.60"
  },
  "devDependencies": {
    "vitest": "^3.2.3"
  }
}
